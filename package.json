{
  "name": "token-vault",
  "version": "0.1.0",
  "description": "Local-first design token studio — tokens live as files in your repo, the editor runs on localhost, git is your history.",
  "type": "module",
  "license": "MIT",
  "bin": {
    "token-vault": "./dist/cli/index.js"
  },
  "files": [
    "dist",
    "templates"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev:app": "vite",
    "build:app": "vite build",
    "build:node": "tsup",
    "build": "pnpm build:node && pnpm build:app",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "cli": "node --experimental-strip-types src/cli/index.ts"
  },
  "dependencies": {
    "@base-ui/react": "^1.6.0",
    "@fontsource-variable/geist": "^5.2.9",
    "@hono/node-server": "^1.14.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "bezier-easing": "^2.1.0",
    "chokidar": "^4.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "commander": "^14.0.0",
    "culori": "^4.0.2",
    "hono": "^4.7.0",
    "lucide-react": "^1.23.0",
    "shadcn": "^4.13.0",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "ws": "^8.18.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.2",
    "@types/culori": "^4.0.1",
    "@types/node": "^26.1.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^6.0.3",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tailwindcss": "^4.3.2",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "vite": "^8.1.3",
    "vitest": "^4.1.9"
  }
}
